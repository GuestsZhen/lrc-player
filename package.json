{
    "name": "lrc-player",
    "version": "6.0.5",
    "description": "简谱 lrc 播放器｜可能是你所能见到的最好用的歌词制作工具",
    "repository": "https://github.com/GuestsZhen/lrc-player.git",
    "author": "magic-akari <akari.ccino@gmail.com>",
    "license": "MIT",
    "keywords": [
        "lrc",
        "lrc player",
        "lyric",
        "lyric player"
    ],
    "bugs": "https://github.com/GuestsZhen/lrc-player/issues",
    "homepage": "https://github.com/GuestsZhen/lrc-player#readme",
    "files": [
        "src",
        "build"
    ],
    "packageManager": "pnpm@10.11.0",
    "type": "module",
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "fix:fmt": "dprint fmt",
        "check:fmt": "dprint check",
        "check:lint": "oxlint src -D correctness",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major",
        "cap:sync": "npm run build && npx cap sync && python3 scripts/register-mediastore-plugin.py",
        "cap:android:deploy": "npm run cap:sync && cd android && ./gradlew assembleDebug --no-daemon && cd .. && adb install -r android/app/build/outputs/apk/debug/app-debug.apk && adb shell pm grant com.lrcplayer.app android.permission.READ_EXTERNAL_STORAGE && adb shell pm grant com.lrcplayer.app android.permission.READ_MEDIA_AUDIO && adb shell appops set com.lrcplayer.app MANAGE_EXTERNAL_STORAGE allow && adb shell am force-stop com.lrcplayer.app && sleep 2 && adb shell am start -n com.lrcplayer.app/.MainActivity && echo '✅ 部署完成，请测试'",
        "cap:ios": "npx cap run ios",
        "cap:android": "npx cap run android",
        "cap:open:ios": "npx cap open ios",
        "cap:open:android": "npx cap open android"
    },
    "imports": {
        "#const/*": "./src/const/*"
    },
    "dependencies": {
        "@capacitor/android": "^8.3.0",
        "@capacitor/cli": "^7.6.1",
        "@capacitor/core": "^8.3.0",
        "@capacitor/ios": "^8.3.0",
        "@capacitor/preferences": "^8.0.1",
        "@capawesome/capacitor-file-picker": "^8.0.2",
        "@lrc-maker/lrc-parser": "^0.1.17",
        "@wavesurfer/react": "^1.0.11",
        "essentia.js": "^0.1.3",
        "react": "^18.2.0",
        "react-color": "^2.19.3",
        "react-dom": "^18.2.0",
        "soundtouchjs": "^0.3.0",
        "wavesurfer.js": "^7.9.5",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@swc/core": "^1.11.29",
        "@types/node": "^22.15.21",
        "@types/react": "^18.2.0",
        "@types/react-color": "^3.0.13",
        "@types/react-dom": "^18.2.0",
        "core-js": "^3.42.0",
        "dprint": "^0.50.0",
        "gen_dep_tag": "^0.0.3",
        "lightningcss": "1.30.1",
        "oxlint": "^0.16.11",
        "rollup-plugin-externals": "^0.0.1",
        "rollup-plugin-swc3": "^0.12.1",
        "toggle-switch-css": "^1.0.3",
        "typescript": "^5.8.3",
        "vite": "^6.3.5"
    }
}
